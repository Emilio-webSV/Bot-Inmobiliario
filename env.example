# ============================================================
#  CONFIGURACIÓN DEL BOT  (copia este archivo como ".env")
# ============================================================
#  En Railway NO subes este archivo: pegas cada variable en
#  la sección "Variables". En local sí creas un archivo .env.
# ============================================================

# --- EL CEREBRO: elige proveedor con UNA sola variable -------
#  IA_PROVIDER=gemini  -> usa Google Gemini (GRATIS, 1,500 msjs/día, sin errores 429)
#  IA_PROVIDER=groq    -> usa Groq (Llama). Más rápido, pero el gratis se topa pronto.
#  Para CAMBIAR de cerebro, solo cambias esta línea. Nada más.
IA_PROVIDER=gemini

# --- Gemini (recomendado por ahora) ---
# La sacas GRATIS en https://aistudio.google.com  ->  "Get API key"
GEMINI_API_KEY=pega_aqui_tu_clave_de_gemini
# Modelo. gemini-3.5-flash = buen balance. Para MÁS mensajes gratis al día
# puedes usar gemini-3.5-flash-lite.
GEMINI_MODEL=gemini-3.5-flash-lite

# --- Groq (opcional, pero DÉJALO puesto) ---
# Aunque el cerebro esté en Gemini, las NOTAS DE VOZ se transcriben con Groq
# (es gratis y sus límites van aparte). Sácala en https://console.groq.com/keys
GROQ_API_KEY=pega_aqui_tu_clave_de_groq
# (opcional) Si vuelves a usar Groq como cerebro: llama-3.3-70b-versatile (bueno)
# o llama-3.1-8b-instant (más barato/rápido pero menos listo).
GROQ_MODEL=llama-3.3-70b-versatile

# --- WhatsApp Cloud API (el canal) ---
# Las sacas en https://developers.facebook.com (producto WhatsApp)
WHATSAPP_TOKEN=pega_aqui_tu_token_de_whatsapp
WHATSAPP_PHONE_ID=pega_aqui_tu_phone_number_id
WHATSAPP_API_VERSION=v21.0

# Palabra secreta que TÚ inventas. La usas también al conectar
# el webhook en Meta. Debe ser idéntica en los dos lados.
WHATSAPP_VERIFY_TOKEN=inventa_una_palabra_secreta

# --- Tu número (recibe alertas y reporte semanal) ---
# Con código de país y sin signos. Ej. México: 5215512345678
OWNER_PHONE=52155xxxxxxxx

# --- Contraseña del panel de admin (/admin) ---
# Cámbiala por una tuya. Con esto la agencia entra a dar de alta propiedades.

# --- Nombre de la agencia (lo pones TÚ en la instalación, por cliente) ---
# Cada agencia ve SU nombre; el cliente no lo puede cambiar desde el panel.
AGENCY_NAME=Inmobiliaria del Cliente
ADMIN_PASSWORD=ponuna_contraseña_segura

# --- Puerto (Railway lo pone solo; en local usa 3000) ---
PORT=3000

# --- Carpeta de datos persistente (Volume de Railway) ---
# En Railway: crea un Volume montado en /data y pon esta variable en /data.
# En local NO la pongas (usa ./data por defecto).
DATA_DIR=/data

# --- Instagram y Facebook Messenger (omnicanal) ---
# Token de la página de Facebook conectada (sirve para Messenger e Instagram).
# Se obtiene en Meta para Desarrolladores al conectar la página.
PAGE_ACCESS_TOKEN=

# --- Agrupador de mensajes (tiempos, opcional) ---
# Si el mensaje se ve COMPLETO, el bot contesta rápido (espera corta).
# Si se ve que el cliente VA A SEGUIR escribiendo, espera más antes de contestar.
ESPERA_CORTA_MS=2000
ESPERA_LARGA_MS=10000
